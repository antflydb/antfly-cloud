# Antfly Cloud data-plane base URL, e.g.
# https://<cloud-host>/cloud/v1/<instance-id>/db/v1 or /api/v1 depending on your instance route
ANTFLY_URL=
ANTFLYDB_API_KEY=

DOCSAF_TABLE=docsaf
DOCSAF_BIN=./bin/docsaf
CORPUS_DIR=sample-corpus
DOCSAF_OUTPUT=artifacts/docsaf-source-documents.json
INLINE_CONTENT=1

# If INLINE_CONTENT=0, set a fetchable URL prefix such as s3://bucket/prefix or https://host/docs
BASE_URL=
