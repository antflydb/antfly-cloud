# Antfly Cloud data-plane base URL, for example:
# https://<cloud-host>/cloud/v1/<instance-id>/api/v1
ANTFLY_URL=
ANTFLYDB_API_KEY=

# Table and ingest settings
INGEST_TABLE=mediaaf
INGEST_BATCH_SIZE=50
MEDIA_BASE_URL=

# Description model credentials/settings. Prefer Antfly Cloud inference when your
# selected instance exposes antfly_inference_proxy_url from:
#   antfly cloud connection <instance> --json
DESCRIPTION_PROVIDER=antfly
DESCRIPTION_MODEL=gemini-2.5-flash
ANTFLY_INFERENCE_URL=

# Direct hosted-provider alternatives. Set explicitly; do not silently fall back.
GEMINI_API_KEY=
GOOGLE_API_KEY=
OPENROUTER_API_KEY=

# Optional object storage for staged media
R2_BUCKET=
R2_ENDPOINT_URL=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
